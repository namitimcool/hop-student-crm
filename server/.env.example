# ============================================
# HOP Recruitment CRM - Server Environment Variables
# Copy this file to ".env" and fill in your values.
# ============================================

# Port the backend API runs on (Render sets this automatically in production)
PORT=4000

# Comma-separated list of allowed frontend origins (CORS).
# Include your local dev URL and your deployed Cloudflare Pages URL.
CLIENT_ORIGIN=http://localhost:5173,https://your-app.pages.dev

# ============================================
# Firebase Admin SDK (backend)
# Create a service account in Firebase Console > Project Settings > Service
# Accounts > Generate new private key, then fill these in from that JSON file.
# (Alternative: set FIREBASE_SERVICE_ACCOUNT_PATH to point at a mounted JSON
# file instead of these three fields — see server/firebase.js)
# ============================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_YOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# Google Drive Resume Storage (personal Google account, OAuth 2.0)
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET come from a Google Cloud OAuth 2.0
# Client ID (type "Web application"). GOOGLE_REFRESH_TOKEN is generated once
# by visiting /api/google-drive/auth in a browser — see README.md.
# GOOGLE_DRIVE_FOLDER_ID is the folder in YOUR Drive where resumes are stored.
# ============================================
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REFRESH_TOKEN=paste-the-refresh-token-from-the-auth-flow-here
GOOGLE_DRIVE_FOLDER_ID=1OWVc042UmR2O9NwHLCnxs_Elyx4OxQXN

# ============================================
# Resume OCR Import (OPTIONAL)
# Leave OCR_API_KEY blank to keep this feature disabled. Field extraction
# after OCR is 100% offline (regex + keyword parsing) — no paid AI API is
# used anywhere in this project.
# ============================================
OCR_API_KEY=
OCR_API_URL=https://api.ocr.space/parse/image
OCR_FILE_FIELD=file
OCR_TEXT_RESPONSE_PATH=
