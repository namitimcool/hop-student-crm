# ============================================
# HOP Recruitment CRM - Client Environment Variables
# Copy this file to ".env" (for local dev) and fill in your values.
# In production (Cloudflare Pages), set these under
# Settings > Environment Variables instead.
# ============================================

# Firebase Web App config (Firebase Console > Project Settings > General >
# Your apps > Web app > SDK setup and configuration)
VITE_FIREBASE_API_KEY=PASTE_YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=PASTE_SENDER_ID
VITE_FIREBASE_APP_ID=PASTE_APP_ID

# Backend API base URL — MUST include the trailing /api, since every
# Express route is mounted under /api (see server/index.js).
# Local dev: leave as /api (vite.config.js proxies it to localhost:4000).
# Production (Cloudflare Pages): set to your Render backend URL + /api, e.g.
# VITE_API_BASE_URL=https://hop-recruitment-crm-api.onrender.com/api
# (client/src/api/client.js will still auto-append /api if you forget it,
# but setting it correctly here avoids relying on that fallback.)
VITE_API_BASE_URL=/api
